{
  "expo": {
    "name": "VibranceFlow",
    "slug": "VibranceFlow-mobile",
    "version": "1.0.0",
    "icon": "./src/screens/ios_logo.png",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0d1117"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.VibranceFlow.mobile",
      "infoPlist": {
        "NSCameraUsageDescription": "Camera is used only to scan the pairing QR code from your PC.",
        "NSLocalNetworkUsageDescription": "VibranceFlow connects to your PC on the local network to adjust display settings. No internet servers are used."
      }
    },
    "android": {
      "package": "com.VibranceFlow.mobile",
      "usesCleartextTraffic": true,
      "adaptiveIcon": {
        "foregroundImage": "./src/screens/android_logo.png",
        "backgroundColor": "#0d1117"
      },
      "permissions": ["CAMERA"]
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow VibranceFlow to scan the pairing QR code on your PC screen."
        }
      ],
      "expo-secure-store"
    ]
  }
}
